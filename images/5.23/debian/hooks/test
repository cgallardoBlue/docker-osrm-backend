#!/bin/bash

# See documentation for details:
# https://docs.docker.com/docker-hub/builds/advanced/

if [ "${DOCKERFILE_PATH}" = "Dockerfile.develop" ] || [ "${DOCKERFILE_PATH}" = "Dockerfile.gitpod" ]; then
    echo "No tests (yet) for ${DOCKERFILE_PATH} images."
    exit 0
fi

if command -v docker-compose >/dev/null 2>&1; then
    compose_cmd() { docker-compose --no-ansi "$@"; }
elif docker compose version >/dev/null 2>&1; then
    compose_cmd() { docker compose --ansi never "$@"; }
else
    echo "Docker Compose is not available (docker-compose or docker compose)."
    exit 1
fi

for file in docker-compose*.test.yml; do

    echo "Starting Test in ${file}..."

    # Build test container
    compose_cmd -f "${file}" build sut
    # Test container run
    compose_cmd -f "${file}" up -d && sleep 60
    compose_cmd -f "${file}" logs -f "sut"
    compose_cmd -f "${file}" ps
    #docker-compose --no-ansi -f "${file}" logs --no-color "osrm-backend-db"
    compose_cmd -f "${file}" logs --no-color "osrm-backend"
    compose_cmd -f "${file}" ps "sut" | grep "Exit 0" || exit 1
    compose_cmd -f "${file}" down

    # Test container restart
    compose_cmd -f "${file}" up -d && sleep 60
    compose_cmd -f "${file}" logs -f "sut"
    compose_cmd -f "${file}" ps
    #docker-compose --no-ansi -f "${file}" logs --no-color "osrm-backend-db"
    compose_cmd -f "${file}" logs --no-color "osrm-backend"
    compose_cmd -f "${file}" ps "sut" | grep "Exit 0" || exit 1
    compose_cmd -f "${file}" down -v

done
